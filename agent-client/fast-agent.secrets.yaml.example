# Copy this file to fast-agent.secrets.yaml and fill in your LLM provider API key.
# fast-agent.secrets.yaml is git-ignored and merges over fast-agent.yaml (secrets win).

# openai:
#   api_key: "your_openai_key"

responses:
  api_key: "<your_api_key>"
  base_url: "https://<your_foundry_project>.services.ai.azure.com/openai/v1" # Optional override
  reasoning: "low" # Optional default
  text_verbosity: "low" # Optional default for supporting models
  transport: "sse" # sse | websocket | auto
  web_search:
    enabled: false
    tool_type: web_search # web_search | web_search_preview
    # search_context_size: medium # low | medium | high
    # allowed_domains: ["openai.com", "docs.openai.com"]
    # external_web_access: false # only applies to tool_type=web_search
    # user_location:
    #   type: approximate
    #   city: "Minneapolis"
    #   region: "Minnesota"
    #   country: "US"
    #   timezone: "America/Chicago"