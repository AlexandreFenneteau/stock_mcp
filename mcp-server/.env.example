TENANT_ID=
MCP_CLIENT_ID=
MCP_CLIENT_SECRET=
# Base URL this MCP server is reachable at (must match the Web redirect URI
# registered on the MCP-Server App Registration, e.g. http://localhost:8001).
MCP_SERVER_BASE_URL=http://localhost:8001
# App ID URI exposed by MCP-Server itself (terraform output mcp_server_app_id_uri), e.g. api://mcp-server-xxxxxxxx
MCP_SERVER_APP_ID_URI=
# App ID URI exposed by Backend-API (terraform output backend_api_app_id_uri), e.g. api://backend-api-xxxxxxxx
BACKEND_API_APP_ID_URI=
BACKEND_API_URL=http://localhost:8000
PORT=8001
